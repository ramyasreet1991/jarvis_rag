# ── Jarvis RAG — RunPod RTX 4090 Environment ─────────────────────────────────
# Copy this to .env on your RunPod instance:
#   cp env.runpod .env
#
# GPU budget breakdown (24 GB VRAM):
#   qwen2.5:32b   ~18 GB  (LLM)
#   bge-large     ~ 1 GB  (embeddings, loaded separately)
#   bge-reranker  ~ 1 GB  (reranker, loaded separately)
#   headroom      ~ 4 GB  (KV cache + batch buffers)
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM (Ollama on CUDA) ──────────────────────────────────────────────────────
USE_LOCAL_LLM=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODELS=/workspace/ollama/models    # store models on network volume, not container disk

# Primary: qwen3:32b — latest Qwen3, fits in 24 GB, best reasoning + coding
# Alternatives that fit in 24 GB:
#   qwen3:8b            ~5 GB   (fast, lightweight)
#   qwen3:14b           ~9 GB   (good balance)
#   qwen3:30b-a3b       ~18 GB  (MoE — activates only 3B at a time, very fast)
#   qwen3:32b           ~20 GB  (recommended — best quality)
#   qwen2.5:32b         ~18 GB  (previous gen fallback)
#   llama3.1:8b         ~5 GB   (fast fallback)
LOCAL_LLM_MODEL=qwen3:32b
LOCAL_LLM_FALLBACK=qwen3:8b
LOCAL_LLM_LIGHTWEIGHT=llama3.2:latest
LOCAL_LLM_CTX=8192

# ── Embeddings (Direct HuggingFace CUDA — bypasses Ollama HTTP) ───────────────
USE_LOCAL_EMBED=true
USE_HF_EMBED=true

# BAAI/bge-m3: 2024 model, hybrid dense+sparse retrieval, 100+ languages, ~2 GB VRAM
# Alternatives:
#   BAAI/bge-large-en-v1.5      ~1 GB   (English-only, previous default)
#   BAAI/bge-base-en-v1.5       ~0.4 GB (smaller, lighter)
#   mixedbread-ai/mxbai-embed-large-v1  ~1 GB (strong English alternative)
LOCAL_EMBED_MODEL=BAAI/bge-m3
LOCAL_EMBED_DIMS=1024

# ── Reranker (sentence-transformers on CUDA) ──────────────────────────────────
# bge-reranker-v2-m3: 2024 model, multilingual, BEIR ~56 vs ~52 for v1, ~1 GB VRAM
# Alternatives:
#   BAAI/bge-reranker-large                ~1 GB   (previous default, BEIR ~52)
#   cross-encoder/ms-marco-MiniLM-L-6-v2   ~70 MB  (fast, lower quality)
#   BAAI/bge-reranker-v2-gemma             ~2 GB   (best quality, heavier)
LOCAL_RERANK_MODEL=BAAI/bge-reranker-v2-m3

# ── Vector DB ─────────────────────────────────────────────────────────────────
VECTOR_DB_PROVIDER=qdrant
QDRANT_PATH=/workspace/data/qdrant_db
# CHROMA_PATH=/workspace/data/chroma_db   # kept for rollback

# ── Batch & Retrieval Tuning (GPU can handle larger batches) ──────────────────
BATCH_SIZE=64
RETRIEVAL_TOP_K=30
CHUNK_SIZE=1024
CHUNK_OVERLAP=128

# ── Paths ─────────────────────────────────────────────────────────────────────
DOCS_PATH=/workspace/docs
OUTPUT_DIR=/workspace/output
LOGS_DIR=/workspace/logs
BACKUP_DIR=/workspace/backups
SOURCES_CONFIG_PATH=/workspace/sources_config.json

# ── API ───────────────────────────────────────────────────────────────────────
APP_API_KEY=jarvis-runpod-key
APP_PORT=8000

# ── Cloud Fallbacks (fill in if needed) ───────────────────────────────────────
# ANTHROPIC_API_KEY=
# VOYAGE_API_KEY=
# PINECONE_API_KEY=
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
