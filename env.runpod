# ── Jarvis RAG — RunPod RTX 4090 Environment ─────────────────────────────────
# Copy this to .env on your RunPod instance:
#   cp env.runpod .env
#
# GPU budget breakdown (24 GB VRAM):
#   qwen2.5:32b   ~18 GB  (LLM)
#   bge-large     ~ 1 GB  (embeddings, loaded separately)
#   bge-reranker  ~ 1 GB  (reranker, loaded separately)
#   headroom      ~ 4 GB  (KV cache + batch buffers)
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM (Ollama on CUDA) ──────────────────────────────────────────────────────
USE_LOCAL_LLM=true
OLLAMA_BASE_URL=http://localhost:11434

# Primary: qwen2.5:32b — fits in 24 GB, significantly better than 8b models
# Alternatives that fit in 24 GB:
#   llama3.1:8b         ~5 GB   (fast, lightweight)
#   mistral:7b          ~4 GB   (fast, lightweight)
#   deepseek-r1:14b     ~8 GB   (strong reasoning)
#   llama3.1:70b:q2_K  ~25 GB  (borderline, may cause OOM)
LOCAL_LLM_MODEL=qwen2.5:32b
LOCAL_LLM_FALLBACK=llama3.1:8b
LOCAL_LLM_LIGHTWEIGHT=llama3.2:latest
LOCAL_LLM_CTX=8192

# ── Embeddings (Direct HuggingFace CUDA — bypasses Ollama HTTP) ───────────────
USE_LOCAL_EMBED=true
USE_HF_EMBED=true

# BAAI/bge-large-en-v1.5: MTEB top-10, 1024-dim, ~1 GB VRAM
# Alternatives:
#   BAAI/bge-base-en-v1.5       ~0.4 GB  (smaller, slightly lower quality)
#   BAAI/bge-m3                 ~2 GB    (multilingual, best overall)
#   thenlper/gte-large           ~1 GB   (good alternative to bge-large)
LOCAL_EMBED_MODEL=BAAI/bge-large-en-v1.5
LOCAL_EMBED_DIMS=1024

# ── Reranker (sentence-transformers on CUDA) ──────────────────────────────────
# bge-reranker-large: significantly better than MiniLM-L-6-v2
# Alternatives:
#   cross-encoder/ms-marco-MiniLM-L-6-v2   ~70 MB  (current default, fast)
#   cross-encoder/ms-marco-MiniLM-L-12-v2  ~130 MB (better quality)
#   BAAI/bge-reranker-large                ~1.3 GB (best local reranker)
LOCAL_RERANK_MODEL=BAAI/bge-reranker-large

# ── Vector DB ─────────────────────────────────────────────────────────────────
VECTOR_DB_PROVIDER=chromadb
CHROMA_PATH=/workspace/data/chroma_db

# ── Batch & Retrieval Tuning (GPU can handle larger batches) ──────────────────
BATCH_SIZE=64
RETRIEVAL_TOP_K=30
CHUNK_SIZE=1024
CHUNK_OVERLAP=128

# ── Paths ─────────────────────────────────────────────────────────────────────
DOCS_PATH=/workspace/docs
OUTPUT_DIR=/workspace/output
LOGS_DIR=/workspace/logs
BACKUP_DIR=/workspace/backups
SOURCES_CONFIG_PATH=/workspace/sources_config.json

# ── API ───────────────────────────────────────────────────────────────────────
APP_API_KEY=jarvis-runpod-key
APP_PORT=8000

# ── Cloud Fallbacks (fill in if needed) ───────────────────────────────────────
# ANTHROPIC_API_KEY=
# VOYAGE_API_KEY=
# PINECONE_API_KEY=
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
