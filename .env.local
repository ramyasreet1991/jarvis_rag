# ── Jarvis RAG — Local Mac M2 Environment ────────────────────────────────────
# Copy to .env before running:  cp .env.local .env

# ── Ollama (already running on Mac) ──────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# Available models on this machine (ollama list):
#   mistral:7b        ← use as primary (llama3.1:8b not pulled)
#   llama3.2:latest   ← lightweight fallback
#   nomic-embed-text  ← embeddings (pull if needed: ollama pull nomic-embed-text)
LOCAL_LLM_MODEL=mistral:7b
LOCAL_LLM_FALLBACK=llama3.2:latest
LOCAL_LLM_LIGHTWEIGHT=llama3.2:latest
LOCAL_EMBED_MODEL=nomic-embed-text

# ── Local Data Paths (relative to project root) ───────────────────────────────
CHROMA_PATH=./data/chroma_db
DOCS_PATH=./docs
SOURCES_CONFIG_PATH=./sources_config.json
BACKUP_DIR=./backups
LOGS_DIR=./logs
OUTPUT_DIR=./output

# ── API Server ────────────────────────────────────────────────────────────────
APP_PORT=8000
APP_API_KEY=jarvis-local-key

# ── Optional Cloud Keys (leave blank to use local-only mode) ─────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
VOYAGE_API_KEY=
COHERE_API_KEY=
PINECONE_API_KEY=
QDRANT_URL=
QDRANT_API_KEY=
